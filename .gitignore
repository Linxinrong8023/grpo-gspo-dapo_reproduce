# ── Python 缓存（即使在允许的目录内也忽略）───────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
.eggs/
build/
dist/

# ── 虚拟环境 ──────────────────────────────────────────────────────────────────
.venv/
venv/
env/

# ── 模型权重 ──────────────────────────────────────────────────────────────────
models/
*.bin
*.safetensors
*.pt
*.ckpt

# ── 数据集（只忽略数据文件，保留目录结构）─────────────────────────────────────
datasets/**/*.jsonl
datasets/**/*.parquet
datasets/**/*.csv
datasets/**/*.json
datasets/**/*.yaml
datasets/**/*.lock
datasets/**/*.metadata
datasets/**/.cache/
!datasets/**/.gitkeep

# ── 训练输出 ──────────────────────────────────────────────────────────────────
outputs/

# ── WandB ─────────────────────────────────────────────────────────────────────
wandb/

# ── 编辑器 / IDE ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── 临时 / 日志 ───────────────────────────────────────────────────────────────
*.log
*.tmp
tmp/

# ── 本地同步脚本 ──────────────────────────────────────────────────────────────
sync.sh

# ── 其他不需要追踪的目录 ──────────────────────────────────────────────────────
docs/
notes/
tests/
